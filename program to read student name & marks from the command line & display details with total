#include <stdio.h>
#include <stdlib.h>

int main(int argc, char *argv[]) {
    int i;
    float total = 0;

    if (argc < 3) {
        printf("Usage: %s <Name> <marks1> <marks2> ...\n", argv[0]);
        return 1;
    }

    char *name = argv[1];

    for (i = 2; i < argc; i++) {
        total += atof(argv[i]);  
    }

    printf("Student Name: %s\n", name);
    printf("Total Marks: %.2f\n", total);

    return 0;
}
